# ---- copy to .env and fill in. NEVER commit .env ----

# Server
PORT=8787
NODE_ENV=development
# Public origin (used for payment redirect/callback URLs). Set to your domain in prod.
PUBLIC_URL=http://localhost:8787

# Auth — generate strong random values:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
# AES-256 key (32 bytes, base64url) used to encrypt payment provider secrets at rest:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SECRETS_KEY=change-me-32-byte-base64url-key

# The first account created with this email is granted the admin role.
ADMIN_EMAIL=you@example.com

# Optional: seed payment provider keys from env instead of the admin page.
# Leave blank and configure them in the admin dashboard instead.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
